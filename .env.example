# API Passanota (server-side only — BFF proxy)
PASSANOTA_API_URL=http://localhost:8000

# Supabase Auth (Settings > API) — inlined at build time
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Public frontend URL (magic links / redirects — must match Supabase Auth URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: set to false when API is localhost (default auto-detects)
# PASSANOTA_API_USE_IAM=false
