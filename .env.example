# API Passanota — chave da API do projeto (mesmo valor de API_KEY no backend)
PASSANOTA_API_URL=http://localhost:8000
PASSANOTA_API_KEY=sua-api-key-do-projeto

# Supabase Auth (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# URL do frontend (redirect magic link — deve coincidir com Supabase Auth URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
